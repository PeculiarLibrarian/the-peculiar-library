@prefix library: <https://peculiar-librarian.org/library/> .
@prefix padi: <https://doi.org/10.5281/zenodo.18894084/> .
@prefix skos: <http://www.w3.org/2004/02/skos/core#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .

# 1. The Circular Paradox (Breaking Hierarchy)
library:InfiniteLoop a skos:Concept ;
    skos:prefLabel "The Ouroboros"@en ;
    skos:broader library:InfiniteLoop ; 
    padi:hasDepthIndex "0.99"^^xsd:float .

# 2. Semantic Collision (An ID acting as two things)
library:CollisionNode a skos:Concept ;
    skos:prefLabel "I am a Concept"@en ;
    padi:hasDepthIndex "0.50"^^xsd:float .

library:CollisionNode a library:RestrictedAsset ; # This should conflict
    library:securityLevel "High" .

# 3. The Type Mismatch (The 'Silent Killer')
library:BadMath a skos:Concept ;
    skos:prefLabel "Bad Math"@en ;
    padi:hasDepthIndex "Not-A-Number"^^xsd:float .
